{
    "version": "2.0.0",
    "tasks": [
        /* --- PREP & CLEANUP TASKS --- */
        {
            "label": "prep: Clean Workspace",
            "type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"if (Test-Path 'Scripts') { Remove-Item -Path 'Scripts' -Recurse -Force -ErrorAction SilentlyContinue }; if (Test-Path 'SKSE') { Remove-Item -Path 'SKSE' -Recurse -Force -ErrorAction SilentlyContinue }; exit 0"
			],
            "presentation": { "reveal": "silent" }
        },
        {
            "label": "prep: Copy Core",
            "type": "shell",
            "command": "Copy-Item -Path './core/Scripts' -Destination '.' -Recurse -Force; Copy-Item -Path './core/SKSE' -Destination './' -Recurse -Force",
            "presentation": { "reveal": "silent" }
        },
        {
            "label": "prep: Overlay OstimNet",
            "type": "shell",
            "command": "Copy-Item -Path './handler_ostimnet/Scripts/*' -Destination './Scripts/.' -Recurse -Force",
            "presentation": { "reveal": "silent" }
        },
        {
            "label": "prep: Overlay DOM",
            "type": "shell",
            "command": "Copy-Item -Path './handler_dom/Scripts/*' -Destination './Scripts/.' -Recurse -Force",
            "presentation": { "reveal": "silent" }
        },
        {
            "label": "prep: Overlay UDNG",
            "type": "shell",
            "command": "Copy-Item -Path './handler_udng/Scripts/*' -Destination './Scripts/.' -Recurse -Force",
            "presentation": { "reveal": "silent" }
        },

        /* --- BUILD & DISTRIBUTE --- */
		{
			"label": "prep: Create Script Folders",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"New-Item -Path 'Scripts/Source' -ItemType Directory -Force -ErrorAction SilentlyContinue | Out-Null"
			],
			"presentation": {
				"reveal": "silent",
				"close": true
			},
			"problemMatcher": []
		}
        {
            "label": "pyro: Compile",
            "type": "pyro",
            "projectFile": "skyrimse.ppj",
            "gamePath": "C:\\Skyrim\\dev\\skyrim",
            "problemMatcher": ["$PapyrusCompiler"]
        },
        {
            "label": "distribute: PEX to All",
            "type": "shell",
            "command": "uv run python_scripts/copy-pex.py --source Scripts --destination handler_ostimnet/Scripts handler_dom/Scripts handler_udng/Scripts core/Scripts",
            "presentation": { "reveal": "always" }
        },
        {
            "label": "distribute: PEX to OstimNet",
            "type": "shell",
            "command": "uv run python_scripts/copy-pex.py --source Scripts --destination handler_ostimnet/Scripts core/Scripts",
            "presentation": { "reveal": "always" }
        },
        {
            "label": "distribute: PEX to Core",
            "type": "shell",
            "command": "uv run python_scripts/copy-pex.py --source Scripts --destination core/Scripts",
            "presentation": { "reveal": "always" }
        },
        /* --- Copy ESP files --- */
        {
            "label": "copy: SkyrimNet_SexLab.esp to Core",
            "type": "shell",
            "command": "Copy-Item -Path './SkyrimNet_SexLab.esp' -Destination './core' -Recurse -Force",
            "presentation": { "reveal": "always" }
        },
        {
            "label": "copy: SkyrimNet_SexLab.esp to Core",
            "type": "shell",
            "command": "Copy-Item -Path './SkyrimNet_SexLab.esp' -Destination './core/.' -Recurse -Force",
            "presentation": { "reveal": "always" }
        },
        {
            "label": "copy: SkyrimNet_SexLab_Handler_OstimeNet.esp to Handler_OstimNet",
            "type": "shell",
            "command": "Copy-Item -Path './SkyrimNet_SexLab_Handler_OstimNet.esp' -Destination './handler_ostimnet/.' -Recurse -Force",
            "presentation": { "reveal": "always" }
        },

        /* --- PIPELINES --- */
        {
            "label": "Build: All Handlers",
            "dependsOrder": "sequence",
            "dependsOn": [
                "prep: Clean Workspace",
				"prep: Create Script Folders",
                "prep: Copy Core",
                "prep: Overlay OstimNet",
                "prep: Overlay DOM",
                "prep: Overlay UDNG",
                "pyro: Compile",
                "distribute: PEX to All",
                "copy: SkyrimNet_SexLab.esp to Core",
                "copy: SkyrimNet_SexLab_Handler_OstimNet.esp to Handler_OstimNet"
            ],
            "group": { "kind": "build", "isDefault": false }
        },
        {
            "label": "Build: OstimNet",
            "dependsOrder": "sequence",
            "dependsOn": [
                "prep: Clean Workspace",
				"prep: Create Script Folders",
                "prep: Copy Core",
                "prep: Overlay OstimNet",
                "pyro: Compile",
                "distribute: PEX to OstimNet",
                "copy: SkyrimNet_SexLab.esp to Core",
                "copy: SkyrimNet_SexLab_Handler_OstimNet.esp to Handler_OstimNet"
            ]
        },
        {
            "label": "Build: Core Only",
            "dependsOrder": "sequence",
            "dependsOn": [
                "prep: Clean Workspace",
				"prep: Create Script Folders",
                "prep: Copy Core",
                "pyro: Compile",
                "distribute: PEX to Core",
                "copy: SkyrimNet_SexLab.esp to Core"
            ]
        }
    ]
}