{
    "version": "2.0.0",
    "tasks": [
        /* --- PREP & CLEANUP TASKS --- */
        {
            "label": "prep: Clean Workspace",
            "type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"if (Test-Path 'Scripts') { Remove-Item -Path 'Scripts' -Recurse -Force -ErrorAction SilentlyContinue }; Get-ChildItem -Path *.esp, *.esl -ErrorAction SilentlyContinue | Remove-Item -Force; if (Test-Path 'SKSE') { Remove-Item -Path 'SKSE' -Recurse -Force -ErrorAction SilentlyContinue }; exit 0"
			],
            "presentation": { "reveal": "silent" }
        },
        {
            "label": "prep: Copy Core",
            "type": "shell",
            "command": "Copy-Item -Path './core/Scripts/Source/*.psc' -Destination './Scripts/Source/' -Force; Copy-Item -Path './core/*.esp' -Destination './' -Force; Copy-Item -Path './core/SKSE' -Destination './' -Recurse -Force",
            "presentation": { "reveal": "silent" }
        },
        {
            "label": "prep: Overlay OstimNet",
            "type": "shell",
            "command": "Copy-Item -Path './handler_ostimnet/Scripts/Source/*' -Destination './Scripts/Source/' -Recurse -Force; Copy-Item -Path './handler_ostimnet/*.esl' -Destination './' -Force",
            "presentation": { "reveal": "silent" }
        },
        {
            "label": "prep: Overlay DOM",
            "type": "shell",
            "command": "Copy-Item -Path './handler_dom/Scripts/Source/*' -Destination './Scripts/Source/' -Recurse -Force; Copy-Item -Path './handler_dom/*.esl' -Destination './' -Force",
            "presentation": { "reveal": "silent" }
        },
        {
            "label": "prep: Overlay UDNG",
            "type": "shell",
            "command": "Copy-Item -Path './handler_udng/Scripts/Source/*' -Destination './Scripts/Source/' -Recurse -Force; Copy-Item -Path './handler_udng/*.esl' -Destination './' -Force",
            "presentation": { "reveal": "silent" }
        },

        /* --- BUILD & DISTRIBUTE --- */
		{
			"label": "prep: Create Script Folders",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"New-Item -Path 'Scripts/Source' -ItemType Directory -Force -ErrorAction SilentlyContinue | Out-Null"
			],
			"presentation": {
				"reveal": "silent",
				"close": true
			},
			"problemMatcher": []
		}
        {
            "label": "pyro: Compile",
            "type": "pyro",
            "projectFile": "skyrimse.ppj",
            "gamePath": "C:\\Skyrim\\dev\\skyrim",
            "problemMatcher": ["$PapyrusCompiler"]
        },
        {
            "label": "distribute: PEX to All",
            "type": "shell",
            "command": "uv run python_scripts/copy-pex.py --source Scripts --destination handler_ostimnet/Scripts handler_dom/Scripts handler_udng/Scripts core/Scripts",
            "presentation": { "reveal": "always" }
        },
        {
            "label": "distribute: PEX to Core",
            "type": "shell",
            "command": "uv run python_scripts/copy-pex.py --source Scripts --destination core/Scripts",
            "presentation": { "reveal": "always" }
        },
        {
            "label": "save: Update Core ESP",
            "type": "shell",
            "command": "Copy-Item -Path './SkyrimNet_SexLab.esp' -Destination './core/SkyrimNet_SexLab.esp' -Force",
            "presentation": { "reveal": "silent" }
        },

        /* --- PIPELINES --- */
        {
            "label": "Build: All Handlers",
            "dependsOrder": "sequence",
            "dependsOn": [
                "prep: Clean Workspace",
				"prep: Create Script Folders",
                "prep: Copy Core",
                "prep: Overlay OstimNet",
                "prep: Overlay DOM",
                "prep: Overlay UDNG",
                "pyro: Compile",
                "distribute: PEX to All",
                "save: Update Core ESP"
            ],
            "group": { "kind": "build", "isDefault": true }
        },
        {
            "label": "Build: Core Only",
            "dependsOrder": "sequence",
            "dependsOn": [
                "prep: Clean Workspace",
				"prep: Create Script Folders",
                "prep: Copy Core",
                "pyro: Compile",
                "distribute: PEX to Core"
            ]
        }
    ]
}